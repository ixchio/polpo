{
  "name": "@polpo-ai/drizzle",
  "version": "0.6.9",
  "description": "Drizzle ORM store implementations for the Polpo AI agent orchestration platform (PostgreSQL + SQLite)",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "sideEffects": false,
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "prepublishOnly": "tsc"
  },
  "dependencies": {
    "@polpo-ai/core": "workspace:*",
    "@polpo-ai/vault-crypto": "workspace:*",
    "drizzle-orm": "^0.44.0",
    "nanoid": "^5.1.2"
  },
  "peerDependencies": {
    "postgres": "^3.4.0",
    "better-sqlite3": "^11.0.0 || ^12.0.0"
  },
  "peerDependenciesMeta": {
    "postgres": {
      "optional": true
    },
    "better-sqlite3": {
      "optional": true
    }
  },
  "devDependencies": {
    "typescript": "^5.7.3",
    "@types/better-sqlite3": "^7.6.8",
    "postgres": "^3.4.0",
    "better-sqlite3": "^11.0.0",
    "drizzle-kit": "^0.31.0"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "license": "Apache-2.0",
  "keywords": [
    "polpo",
    "drizzle",
    "orm",
    "postgresql",
    "sqlite",
    "ai-agents",
    "orchestration"
  ],
  "author": "OpenPolpo Contributors",
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/lumea-labs/polpo.git",
    "directory": "packages/drizzle"
  },
  "homepage": "https://github.com/lumea-labs/polpo/tree/main/packages/drizzle",
  "bugs": {
    "url": "https://github.com/lumea-labs/polpo/issues"
  }
}
